# Copy this file to .env and fill in values.

# ── Deployment mode ────────────────────────────────────────────────────────
# "local"  → Ollama (llama3.1:8b), no RAGAS scoring
# "oracle" → Groq API, RAGAS enabled
# "gemini" → Gemini Flash 2.0, use run_batch_evaluation.py
DEPLOYMENT=local

# ── Gemini (DEPLOYMENT=gemini) ─────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Groq (DEPLOYMENT=oracle) ───────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Services (override if running Qdrant / Neo4j remotely) ─────────────────
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=meridian123

# ── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── GCP public IP (used for Grafana subpath routing) ────────────────────────
GCP_HOST=http://35.253.235.148
